# ─────────────────────────────────────────────────────────────────────────────
# .env.sample — environment variables for the Chista Asabru development stack
#
# Usage
#   cp .env.sample .env
#   # Fill in the required values (marked with <REQUIRED>)
#   docker compose up -d
#
# IMPORTANT
#   • Never commit the real .env file.  It is listed in .gitignore.
#   • In production, inject secrets via your secrets manager
#     (HashiCorp Vault, AWS Secrets Manager, Docker Secrets, etc.).
# ─────────────────────────────────────────────────────────────────────────────

# ── Chista Asabru proxy ───────────────────────────────────────────────────────
CONFIG_FILE_PATH=/opt/asabru/config/config.xml
# CONFIG_FILE_URL=https://your-config-server/config.xml   # optional: download on startup
PLUGINS_FOLDER_PATH=/opt/asabru/plugins
PUBLIC_FOLDER_PATH=/opt/asabru/public
LOGGER_TYPE=FILE                          # FILE | NET | STDOUT
# NETWORK_LOGGER_HOST=fluent-bit          # required when LOGGER_TYPE=NET
# NETWORK_LOGGER_PORT=5170

# ── TLS (required for TLS-enabled endpoints) ─────────────────────────────────
# SSL_CERT_FILE_PATH=/opt/asabru/certs/server.pem
# SSL_KEY_FILE_PATH=/opt/asabru/certs/server.key
# SSL_VERIFY_CERT=true

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<REQUIRED>
CLICKHOUSE_2_USER=fluentbit
CLICKHOUSE_2_PASSWORD=<REQUIRED>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=<REQUIRED>

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<REQUIRED>

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=<REQUIRED>

# ── MySQL (Rundeck) ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=<REQUIRED>
MYSQL_RUNDECK_PASSWORD=<REQUIRED>

# ── Snowflake exporter (optional) ─────────────────────────────────────────────
# SNOWFLAKE_EXPORTER_ACCOUNT=
# SNOWFLAKE_EXPORTER_USERNAME=
# SNOWFLAKE_EXPORTER_PASSWORD=
# SNOWFLAKE_EXPORTER_ROLE=
# SNOWFLAKE_EXPORTER_WAREHOUSE=
